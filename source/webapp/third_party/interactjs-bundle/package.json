{
  "name": "interactjs-bundle",
  "version": "1.10.27",
  "description": "interact.js — drag/resize/snap primitives used by the highlight editor timeline",
  "main": "index.js",
  "scripts": {
    "test": "echo \"bundle exists\" && exit 0",
    "build:clean": "rm -rf dist && mkdir -p dist/js",
    "build:copy": "cp -v ./node_modules/interactjs/dist/interact.min.js ./dist/js",
    "build": "npm-run-all -s build:clean build:copy"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "interactjs": "1.10.27"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
